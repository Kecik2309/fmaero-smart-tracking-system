{
  "database": {
    "rules": "database.rules.json"
  },
  "hosting": {
    "public": ".",
    "redirects": [
      {
        "source": "/",
        "destination": "/login.html",
        "type": 302
      }
    ],
    "ignore": [
      "firebase.json",
      "database.rules.json",
      ".firebaserc",
      ".gitignore",
      "**/.*",
      "**/node_modules/**"
    ]
  }
}
